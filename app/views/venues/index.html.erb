<div class="container my-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Venues</h1>
    <%= link_to "Create New Venue", new_venue_path, class: "btn btn-primary" %>
  </div>

  <div class="row">
    <% @venues.each do |venue| %>
      <div class="col-md-6 mb-4">
        <div class="card shadow">
          <div class="card-body">
            <h5 class="card-title"><%= venue.name %></h5>
            <p class="text-muted mb-2">
              <i class="bi bi-geo-alt"></i> <%= venue.address %>
            </p>
            <% if venue.capacity.present? %>
              <p class="text-muted mb-2">
                <i class="bi bi-people"></i> Capacity: <%= venue.capacity %>
              </p>
            <% end %>
            <p class="text-muted mb-3">
              <i class="bi bi-calendar-event"></i> <%= pluralize(venue.events.count, 'event') %>
            </p>
            
            <div class="d-flex gap-2">
              <%= link_to "View Details", venue_path(venue), class: "btn btn-sm btn-outline-primary" %>
              <% if user_signed_in? %>
                <%= link_to "Edit", edit_venue_path(venue), class: "btn btn-sm btn-warning" %>
                <%= button_to "Delete", venue_path(venue), method: :delete, 
                    data: { confirm: "Are you sure?" }, 
                    class: "btn btn-sm btn-danger" %>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>