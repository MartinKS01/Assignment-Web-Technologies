<div class="container my-5">
  <h1>Venues</h1>

  <div class="row g-3">
    <% @venues.each do |venue| %>

      <div class="col-md-4">
        <div class="card shadow-sm p-3">

          <h5><%= venue.name %></h5>
          <p><%= venue.address %></p>
          <p>Capacity: <%= venue.capacity %></p>

          <%= link_to "View", venue_path(venue), class: "btn btn-sm btn-outline-primary" %>

        </div>
      </div>

    <% end %>
  </div>
</div>