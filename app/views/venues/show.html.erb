<div class="container my-5">

  <h1><%= @venue.name %></h1>

  <p class="text-muted"><%= @venue.address %></p>

  <p>Capacity: <strong><%= @venue.capacity %></strong></p>

  <hr>

  <h3>Events</h3>

  <% @venue.events.each do |event| %>
    <div class="card p-3 mb-2">

      <h5><%= link_to event.title, event_path(event) %></h5>

      <p>
        📅 <%= event.start_date.strftime("%d-%m-%Y %H:%M") %>
      </p>

    </div>
  <% end %>

</div>