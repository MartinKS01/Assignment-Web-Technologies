<div class="container my-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Categories</h1>
    <%= link_to "Create New Category", new_category_path, class: "btn btn-primary" %>
  </div>

  <div class="row">
    <% @categories.each do |category| %>
      <div class="col-md-4 mb-4">
        <div class="card shadow h-100">
          <div class="card-body d-flex flex-column">
            <h5 class="card-title"><%= category.name %></h5>
            <% if category.description.present? %>
              <p class="card-text flex-grow-1"><%= category.description %></p>
            <% end %>
            <p class="text-muted mb-3">
              <i class="bi bi-calendar-event"></i> <%= pluralize(category.events.count, 'event') %>
            </p>
            
            <div class="d-flex gap-2 mt-auto">
              <%= link_to "View Details", category_path(category), class: "btn btn-sm btn-outline-primary" %>
              <%= link_to "Edit", edit_category_path(category), class: "btn btn-sm btn-warning" %>
              <%= button_to "Delete", category_path(category), method: :delete, 
                  data: { confirm: "Are you sure?" }, 
                  class: "btn btn-sm btn-danger" %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>