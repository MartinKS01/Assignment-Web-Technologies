<%= form_with(model: category, local: true, class: "mt-4") do |form| %>
  <% if @event.errors.any? %>
    <div class="alert alert-danger">
      <h4>
        <%= pluralize(@event.errors.count, "error") %>
        prevented this event from being saved:
      </h4>

      <ul>
        <% @event.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= form.label :name, class: "form-label" %>
    <%= form.text_field :name, class: "form-control", placeholder: "e.g., Workshop", required: true %>
  </div>

  <div class="mb-3">
    <%= form.label :description, class: "form-label" %>
    <%= form.text_area :description, class: "form-control", rows: 4, placeholder: "Brief description of this category" %>
  </div>

  <div class="mt-4">
    <%= form.submit category.new_record? ? "Create Category" : "Update Category", class: "btn btn-primary" %>
  </div>
<% end %>