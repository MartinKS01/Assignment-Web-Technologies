<div class="container my-5">
  <h1><%= @category.name %></h1>

  <div class="row g-3 mt-3">

    <% @category.events.each do |event| %>
      <div class="col-md-6">
        <div class="card p-3 shadow-sm">

          <h5><%= link_to event.title, event_path(event) %></h5>

          <p class="text-muted">
            📅 <%= event.start_date.strftime("%d-%m-%Y %H:%M") %>
          </p>

        </div>
      </div>
    <% end %>

  </div>
</div>