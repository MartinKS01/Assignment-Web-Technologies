<%= form_with(model: event, local: true, class: "mt-4") do |form| %>
  <% if @event.errors.any? %>
    <div class="alert alert-danger">
      <h4>
        <%= pluralize(@event.errors.count, "error") %>
        prevented this event from being saved:
      </h4>

      <ul>
        <% @event.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= form.label :title, class: "form-label" %>
    <%= form.text_field :title, class: "form-control", placeholder: "Enter event title", required: true %>
  </div>

  <div class="mb-3">
    <%= form.label :category_id, "Category", class: "form-label" %>
    <%= form.select :category_id, Category.all.map { |c| [c.name, c.id] }, { prompt: "Select a category" }, class: "form-select", required: true %>
  </div>

  <div class="mb-3">
    <%= form.label :venue_id, "Venue", class: "form-label" %>
    <%= form.select :venue_id, Venue.all.map { |v| [v.name, v.id] }, { prompt: "Select a venue" }, class: "form-select", required: true %>
  </div>

  <div class="row">
    <div class="col-md-6 mb-3">
      <%= form.label :start_date, "Start Date & Time", class: "form-label" %>
      <%= form.datetime_local_field :start_date, class: "form-control", required: true %>
    </div>

    <div class="col-md-6 mb-3">
      <%= form.label :end_date, "End Date & Time", class: "form-label" %>
      <%= form.datetime_local_field :end_date, class: "form-control", required: true %>
    </div>
  </div>

  <div class="mb-3">
    <%= form.label :max_attendees, "Maximum Attendees", class: "form-label" %>
    <%= form.number_field :max_attendees, class: "form-control", min: 1, placeholder: "e.g., 50", required: true %>
  </div>

  <div class="mb-3">
    <%= form.label :description, class: "form-label" %>
    <%= form.rich_text_area :description, class: "form-control" %>
    <small class="text-muted">Use the toolbar to format your event description</small>
  </div>

  <div class="mt-4">
    <%= form.submit event.new_record? ? "Create Event" : "Update Event", class: "btn btn-primary" %>
  </div>
<% end %>