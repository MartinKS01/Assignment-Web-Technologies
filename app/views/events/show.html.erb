<div class="container my-5">
  <div class="card shadow p-4">
    <div class="d-flex justify-content-between align-items-start mb-3">
      <div>
        <h1><%= @event.title %></h1>
        <p class="text-muted">
          <%= @event.category.name %> • <%= @event.venue.name %>
        </p>
      </div>
      <span class="badge bg-<%= @event.status %> fs-5">
        <%= @event.status.titleize %>
      </span>
    </div>

    <div class="mb-4">
      <%= @event.description %>
    </div>

    <!-- Event Details -->
    <ul class="list-group my-3">
      <li class="list-group-item">
        📅 Inicio: <%= @event.start_date.strftime("%d-%m-%Y %H:%M") %>
      </li>
      <li class="list-group-item">
        📅 Término: <%= @event.end_date.strftime("%d-%m-%Y %H:%M") %>
      </li>
      <li class="list-group-item">
        👥 Cupo: <%= @event.confirmed_count %>/<%= @event.max_attendees %>
        <% if @event.available_spots > 0 %>
          <span class="text-success">(<%= @event.available_spots %> disponibles)</span>
        <% else %>
          <span class="text-danger">(Lleno)</span>
        <% end %>
        <% if @event.waitlist_count > 0 %>
          <br>
          <small class="text-warning">👥 <%= @event.waitlist_count %> en lista de espera</small>
        <% end %>
      </li>
      <li class="list-group-item">
        👤 Organizador: <%= @event.organizer.first_name %>
      </li>
    </ul>

    <% if current_user %>
      <div class="card bg-light p-3 my-4">
        <% if @user_registration %>
          <!-- User is already registered -->
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <h5 class="mb-1">
                <% if @user_registration.confirmed? %>
                  ✅ You're registered!
                <% elsif @user_registration.waitlisted? %>
                  ⏳ You're on the waitlist
                <% end %>
              </h5>
              <p class="mb-0 text-muted">
                <% if @user_registration.confirmed? %>
                  Your spot is confirmed. See you at the event!
                <% else %>
                  You'll be notified if a spot becomes available.
                <% end %>
              </p>
            </div>
            <%= button_to "Cancel Registration", 
                event_registration_path(@event, @user_registration), 
                method: :delete,
                data: { confirm: "Are you sure you want to cancel your registration?" },
                class: "btn btn-danger" %>
          </div>
        <% elsif @event.can_register? %>
          <!-- User can register -->
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <h5 class="mb-1">Interested in this event?</h5>
              <p class="mb-0 text-muted">
                <% if @event.full? %>
                  Event is full, but you can join the waitlist!
                <% else %>
                  Register now to secure your spot.
                <% end %>
              </p>
            </div>
            <%= button_to @event.full? ? "Join Waitlist" : "Register for Event", 
                event_registrations_path(@event),
                method: :post,
                class: "btn btn-primary" %>
          </div>
        <% elsif @event.draft? %>
          <div class="alert alert-info mb-0">
            ℹ️ This event is not yet published. Registration will open once it's published.
          </div>
        <% elsif @event.start_date <= Time.current %>
          <div class="alert alert-warning mb-0">
            ⏰ Registration is closed. This event has already started or ended.
          </div>
        <% elsif @event.cancelled? %>
          <div class="alert alert-danger mb-0">
            ❌ This event has been cancelled.
          </div>
        <% end %>
      </div>
    <% end %>

    <!-- Registered Users List (for organizer) -->
    <% if current_user && @event.organizer == current_user %>
      <div class="card mt-4">
        <div class="card-header">
          <h5 class="mb-0">Registered Attendees</h5>
        </div>
        <div class="card-body">
          <h6>Confirmed (<%= @event.confirmed_count %>)</h6>
          <ul class="list-group mb-3">
            <% @event.confirmed_registrations.each do |registration| %>
              <li class="list-group-item">
                ✅ <%= registration.user.first_name %> <%= registration.user.last_name %>
                <small class="text-muted">- Registered <%= time_ago_in_words(registration.created_at) %> ago</small>
              </li>
            <% end %>
          </ul>

          <% if @event.waitlist_count > 0 %>
            <h6>Waitlist (<%= @event.waitlist_count %>)</h6>
            <ul class="list-group">
              <% @event.waitlisted_registrations.each_with_index do |registration, index| %>
                <li class="list-group-item">
                  ⏳ #<%= index + 1 %> - <%= registration.user.first_name %> <%= registration.user.last_name %>
                  <small class="text-muted">- Registered <%= time_ago_in_words(registration.created_at) %> ago</small>
                </li>
              <% end %>
            </ul>
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- Action Buttons for Organizer -->
    <% if current_user && @event.organizer == current_user %>
      <div class="mt-4 d-flex gap-2 flex-wrap">
        <%= link_to "Edit Event", edit_event_path(@event), class: "btn btn-warning" %>
        
        <% if @event.draft? %>
          <%= button_to "Publish Event", publish_event_path(@event), method: :patch, 
              class: "btn btn-success" %>
        <% end %>
        
        <% if @event.draft? || @event.published? %>
          <%= button_to "Cancel Event", cancel_event_path(@event), method: :patch,
              data: { confirm: "Are you sure you want to cancel this event?" },
              class: "btn btn-danger" %>
        <% end %>
        
        <% if @event.draft? %>
          <%= button_to "Delete Event", event_path(@event), method: :delete, 
              data: { confirm: "Are you sure you want to delete this event?" }, 
              class: "btn btn-outline-danger" %>
        <% end %>
      </div>
    <% end %>

    <% if @reviews.any? %>
      <div class="mt-5">
        <h3>Reviews</h3>
        <% @reviews.each do |review| %>
          <div class="card mb-3">
            <div class="card-body">
              <div class="d-flex justify-content-between">
                <strong><%= review.user.first_name %></strong>
                <span>
                  <% review.rating.times do %>⭐<% end %>
                </span>
              </div>
              <p class="mt-2"><%= review.comment %></p>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>