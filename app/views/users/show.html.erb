<div class="container my-5">
  <div class="card p-4 shadow">

    <h1><%= @user.first_name %> <%= @user.last_name %></h1>

    <p><%= @user.email %></p>

    <hr>

    <h4>Registered Events</h4>

    <% @user.registrations.each do |reg| %>
      <p>
        <%= link_to reg.event.title, event_path(reg.event) %>
        - <%= reg.status %>
      </p>
    <% end %>

  </div>
</div>