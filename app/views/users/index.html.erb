<div class="container my-5">
  <h1>Users</h1>

  <div class="row g-3">
    <% @users.each do |user| %>
      <div class="col-md-4">
        <div class="card shadow-sm p-3">

          <h5><%= user.first_name %> <%= user.last_name %></h5>
          <p class="text-muted"><%= user.email %></p>

          <%= link_to "View", user_path(user), class: "btn btn-sm btn-outline-primary" %>

        </div>
      </div>
    <% end %>
  </div>
</div>