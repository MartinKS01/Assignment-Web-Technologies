<div class="container my-5">
  <div class="row justify-content-center">
    <div class="col-md-5">
      <div class="card shadow">
        <div class="card-body p-4">
          <h2 class="card-title text-center mb-4">Forgot Password</h2>
          <p class="text-muted text-center">Enter your email and we'll send you reset instructions.</p>

          <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
            <div class="mb-3">
              <%= f.label :email, class: "form-label" %>
              <%= f.email_field :email, class: "form-control", placeholder: "Enter your email", autofocus: true %>
            </div>

            <div class="d-grid">
              <%= f.submit "Send Reset Instructions", class: "btn btn-primary" %>
            </div>
          <% end %>

          <hr>

          <div class="text-center">
            <p class="mb-1"><%= link_to "Back to Login", new_session_path(resource_name) %></p>
            <p class="mb-0"><%= link_to "Sign Up", new_registration_path(resource_name) %></p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>