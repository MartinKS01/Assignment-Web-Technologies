<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "EventHub" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="EventHub">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.min.css">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="d-flex flex-column min-vh-100">
    <nav class="navbar navbar-dark bg-dark navbar-expand-lg">
      <div class="container-fluid">
        <%= link_to "EventHub", root_path, class: "navbar-brand fw-bold" %>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
          <!-- Left side links -->
          <ul class="navbar-nav me-auto">
            <li class="nav-item">
              <%= link_to "Events", events_path, class: "nav-link" %>
            </li>
            <li class="nav-item">
              <%= link_to "Categories", categories_path, class: "nav-link" %>
            </li>
            <li class="nav-item">
              <%= link_to "Venues", venues_path, class: "nav-link" %>
            </li>
            <% if user_signed_in? && current_user.admin? %>
              <li class="nav-item">
                <%= link_to "Users", users_path, class: "nav-link" %>
              </li>
            <% end %>
          </ul>

          <!-- Right side auth links -->
          <ul class="navbar-nav ms-auto">
            <% if user_signed_in? %>
              <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                  👤 <%= current_user.full_name %>
                  <% if current_user.admin? %>
                    <span class="badge bg-danger ms-1">Admin</span>
                  <% end %>
                </a>
                <ul class="dropdown-menu dropdown-menu-end">
                  <li><%= link_to "Edit Profile", edit_user_registration_path, class: "dropdown-item" %></li>
                  <li><hr class="dropdown-divider"></li>
                  <li>
                    <%= button_to "Log Out", destroy_user_session_path, method: :delete, 
                        class: "dropdown-item text-danger" %>
                  </li>
                </ul>
              </li>
            <% else %>
              <li class="nav-item">
                <%= link_to "Log In", new_user_session_path, class: "nav-link" %>
              </li>
              <li class="nav-item">
                <%= link_to "Sign Up", new_user_registration_path, class: "btn btn-primary ms-2" %>
              </li>
            <% end %>
          </ul>
        </div>
      </div>
    </nav>

    <% flash.each do |type, message| %>
      <div class="alert alert-<%= type == 'notice' ? 'success' : 'danger' %> alert-dismissible fade show mb-0" role="alert">
        <%= message %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% end %>
    
    <%= yield %>

    <footer class="bg-dark text-white py-4 mt-auto">
      <div class="container px-4"> 
        <div class="row gy-3">
          <div class="col-12 col-md-6 text-center text-md-start">
            <p class="mb-0">© 2026 <strong>EventHub Team</strong></p>
          </div>
          <div class="col-12 col-md-6 text-center text-md-end">
            <p class="mb-0">Web Development Course | Year 2026</p>
          </div>
        </div>
      </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>